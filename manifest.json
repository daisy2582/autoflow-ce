{
    "manifest_version": 3,
    "name": "Supago Order Automation",
    "version": "1.0.0",
    "description": "Automates withdrawal order processing on Supago dashboard",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "downloads",
        "windows"
    ],
    "host_permissions": [
        "https://dashboard.supago.online/*",
        "https://api-prod.gatewayhub.live/*",
        "https://staging.api.gatewayhub.live/*",
        "https://webhook.site/*",
        "https://autoflow-ce-api-staging.botauto.online/*",
        "https://autoflow-ce-api.botauto.online/*",
        "http://localhost:3000/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://dashboard.supago.online/*"
            ],
            "js": [
                "utils/logger.js",
                "utils/crypto.js",
                "utils/storage.js",
                "utils/api.js",
                "utils/scraper.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}